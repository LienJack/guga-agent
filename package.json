{
  "name": "guga-agent",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r build",
    "build:cli": "pnpm --filter @guga-agent/cli build",
    "dev:cli": "node --enable-source-maps packages/cli/dist/index.js",
    "debug:cli": "node --enable-source-maps --inspect-brk packages/cli/dist/index.js",
    "init:cli": "pnpm dev:cli init",
    "cli:mock": "pnpm dev:cli run \"hello\" --mock --debug-events --ops",
    "demo:ai-sdk-bridge": "vitest run scripts/ai-sdk-bridge-demo.test.ts --reporter=verbose",
    "demo:ai-sdk-bridge:real": "vitest run scripts/ai-sdk-bridge-real-demo.test.ts --reporter=verbose",
    "install:cli": "pnpm --filter @guga-agent/cli build && node scripts/install-cli-alias.mjs",
    "smoke:packages": "pnpm build && node scripts/package-esm-smoke.mjs",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
