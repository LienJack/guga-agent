{
  "name": "guga-agent",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r build",
    "demo:ai-sdk-bridge": "vitest run scripts/ai-sdk-bridge-demo.test.ts --reporter=verbose",
    "demo:ai-sdk-bridge:real": "vitest run scripts/ai-sdk-bridge-real-demo.test.ts --reporter=verbose",
    "smoke:packages": "pnpm build && node scripts/package-esm-smoke.mjs",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
