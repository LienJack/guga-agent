 * when the consumer checks `sub.name === "someSubagentName"`.
 */
export type SubagentRunStreamUnion<TSubagents extends readonly AnySubAgent[]> =
  {
    [K in keyof TSubagents]: NamedSubagentRunStream<TSubagents[K]>;
