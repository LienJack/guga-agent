export interface SubagentRunStream<
  TOutput = unknown,
  TTools extends readonly (ClientTool | ServerTool)[] = readonly (
    | ClientTool
    | ServerTool
  )[],
> {
  readonly name: string;
  readonly taskInput: Promise<string>;
