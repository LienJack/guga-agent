{
  "name": "@guga-agent/host-sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @guga-agent/host-local-server build && tsc -p tsconfig.json && node ../../scripts/fix-esm-extensions.mjs dist",
    "test": "pnpm --filter @guga-agent/host-local-server build && vitest run",
    "typecheck": "pnpm --filter @guga-agent/host-local-server build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@guga-agent/host-local-server": "workspace:*",
    "@guga-agent/host-protocol": "workspace:*"
  },
  "devDependencies": {
    "@guga-agent/core": "workspace:*",
    "@guga-agent/host-runtime": "workspace:*"
  }
}
