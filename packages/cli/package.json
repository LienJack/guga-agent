{
  "name": "@guga-agent/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "guga": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --filter @guga-agent/cli^... build && tsc -p tsconfig.json && node ../../scripts/fix-esm-extensions.mjs dist",
    "test": "pnpm --filter @guga-agent/cli^... build && vitest run",
    "typecheck": "pnpm --filter @guga-agent/cli^... build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@guga-agent/core": "workspace:*",
    "@guga-agent/host-protocol": "workspace:*",
    "@guga-agent/host-runtime": "workspace:*",
    "@guga-agent/host-sdk": "workspace:*",
    "@guga-agent/plugin-artifact-filesystem": "workspace:*",
    "@guga-agent/plugin-audit-export": "workspace:*",
    "@guga-agent/plugin-eval-runner": "workspace:*",
    "@guga-agent/plugin-memory-jsonl": "workspace:*",
    "@guga-agent/plugin-ops-health": "workspace:*",
    "@guga-agent/plugin-session-jsonl": "workspace:*",
    "@guga-agent/plugin-web-search": "workspace:*",
    "@guga-agent/profile-code-agent": "workspace:*",
    "@guga-agent/profile-deep-research-agent": "workspace:*",
    "@guga-agent/profile-review-agent": "workspace:*",
    "ink": "^7.0.4",
    "react": "^19.2.6",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "ink-testing-library": "^4.0.0",
    "@types/react": "^19.2.15"
  }
}
