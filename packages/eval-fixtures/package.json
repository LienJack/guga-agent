{
  "name": "@guga-agent/eval-fixtures",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/fix-esm-extensions.mjs dist",
    "test": "vitest run",
    "typecheck": "pnpm --filter @guga-agent/plugin-eval-runner build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@guga-agent/core": "workspace:*",
    "@guga-agent/plugin-eval-runner": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.7"
  }
}
